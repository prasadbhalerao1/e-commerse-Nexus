{
  "openapi": "3.0.0",
  "info": {
    "title": "Project Nexus API Uplink",
    "version": "1.0.0",
    "description": "API documentation for the Project Nexus e-commerce system. Design style: Industrial Quantum Brutalism."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "System Health Check",
        "description": "Verifies that the backend server core is active and returns the uptime.",
        "responses": {
          "200": {
            "description": "Uplink healthy."
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "User Registration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["firstName", "lastName", "email", "password"],
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successfully registered. Returns HttpOnly cookie."
          },
          "400": {
            "description": "Validation failed or user already exists."
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "User Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully logged in. Returns HttpOnly cookie."
          },
          "401": {
            "description": "Invalid credentials."
          }
        }
      }
    },
    "/auth/google": {
      "post": {
        "summary": "Google SSO Sign-In",
        "description": "Validates a Google ID token from the frontend, logs in or signs up the user, and returns an HttpOnly cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["idToken"],
                "properties": {
                  "idToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated via Google SSO. Returns HttpOnly cookie."
          },
          "400": {
            "description": "Invalid Google ID token."
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "User Logout",
        "responses": {
          "200": {
            "description": "Cookie cleared successfully."
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Fetch Logged-in Profile",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Returns current user details."
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    },
    "/users/profile": {
      "put": {
        "summary": "Update Profile Details",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "email": { "type": "string", "format": "email" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated." }
        }
      }
    },
    "/users/addresses": {
      "get": {
        "summary": "Get Saved Addresses",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "List of addresses." }
        }
      },
      "post": {
        "summary": "Add Shipping Address",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["street", "city", "state", "zip", "country"],
                "properties": {
                  "street": { "type": "string" },
                  "city": { "type": "string" },
                  "state": { "type": "string" },
                  "zip": { "type": "string" },
                  "country": { "type": "string" },
                  "isDefault": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Address added." }
        }
      }
    },
    "/users/addresses/{addressId}": {
      "delete": {
        "summary": "Remove Address",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "addressId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Address removed." }
        }
      }
    },
    "/products/categories": {
      "get": {
        "summary": "Get Active Categories",
        "responses": {
          "200": { "description": "List of active categories." }
        }
      },
      "post": {
        "summary": "Create Category (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "slug"],
                "properties": {
                  "name": { "type": "string" },
                  "slug": { "type": "string" },
                  "description": { "type": "string" },
                  "parentCategory": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Category created." }
        }
      }
    },
    "/products/cms": {
      "get": {
        "summary": "Get CMS Settings",
        "description": "Retrieves homepage hero banner and featured products.",
        "responses": {
          "200": { "description": "CMS settings." }
        }
      },
      "put": {
        "summary": "Update CMS Settings (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "heroBanner": { "type": "object" },
                  "featuredProducts": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "CMS settings updated." }
        }
      }
    },
    "/products/admin/export": {
      "get": {
        "summary": "Export Products CSV (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Downloads products CSV." }
        }
      }
    },
    "/products/admin/import": {
      "post": {
        "summary": "Import Products CSV (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["csvData"],
                "properties": {
                  "csvData": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Import results (success count & validation errors)." }
        }
      }
    },
    "/products/catalog": {
      "get": {
        "summary": "Query Products Catalog",
        "description": "Faceted query returns catalog products matched using aggregation pipelines.",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "minPrice", "in": "query", "schema": { "type": "number" } },
          { "name": "maxPrice", "in": "query", "schema": { "type": "number" } },
          { "name": "tags", "in": "query", "schema": { "type": "string" } },
          { "name": "minRating", "in": "query", "schema": { "type": "number" } },
          { "name": "limit", "in": "query", "schema": { "type": "number", "default": 20 } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Matched products & dynamic facets." }
        }
      }
    },
    "/products/slug/{slug}": {
      "get": {
        "summary": "Get Single Product Details",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Product document details." }
        }
      }
    },
    "/cart": {
      "get": {
        "summary": "Get Authenticated Cart",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Persisted DB cart." }
        }
      }
    },
    "/cart/sync": {
      "post": {
        "summary": "Merge Local Storage Cart",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items"],
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["product", "quantity"],
                      "properties": {
                        "product": { "type": "string" },
                        "quantity": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Merged cart state." }
        }
      }
    },
    "/coupons": {
      "post": {
        "summary": "Create Coupon (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code", "discountType", "discountValue", "expiresAt"],
                "properties": {
                  "code": { "type": "string" },
                  "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
                  "discountValue": { "type": "number" },
                  "minOrderValue": { "type": "number", "default": 0 },
                  "usageLimit": { "type": "number", "nullable": true },
                  "expiresAt": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Coupon created successfully." }
        }
      }
    },
    "/coupons/validate": {
      "get": {
        "summary": "Validate Coupon Code",
        "parameters": [
          { "name": "code", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "orderValue", "in": "query", "required": true, "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "Coupon details if valid." },
          "400": { "description": "Coupon expired, spent threshold too low, or usage limit exceeded." }
        }
      }
    },
    "/reviews/{productId}": {
      "post": {
        "summary": "Post Product Review",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rating", "title", "comment"],
                "properties": {
                  "rating": { "type": "number", "minimum": 1, "maximum": 5 },
                  "title": { "type": "string" },
                  "comment": { "type": "string" },
                  "images": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Review published." }
        }
      },
      "get": {
        "summary": "Get Product Reviews",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "List of reviews." }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Checkout Placement",
        "description": "Places order. Performs server-side price validations and inventory checks. Supports guest checkout.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["items", "shippingAddress", "billingAddress"],
                "properties": {
                  "guestEmail": { "type": "string", "format": "email" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["product", "qty"],
                      "properties": {
                        "product": { "type": "string" },
                        "qty": { "type": "number" }
                      }
                    }
                  },
                  "shippingAddress": { "type": "object" },
                  "billingAddress": { "type": "object" },
                  "paymentMethod": { "type": "string", "enum": ["Stripe", "PayPal"] },
                  "couponCode": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order submitted successfully." }
        }
      }
    },
    "/orders/my": {
      "get": {
        "summary": "Fetch Logged-in Orders History",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Returns list of client orders." }
        }
      }
    },
    "/orders/admin/analytics": {
      "get": {
        "summary": "Get Admin Analytics (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Returns GMV, conversion rates, active carts count, and 30-day sales history." }
        }
      }
    },
    "/orders/admin/all": {
      "get": {
        "summary": "Get All System Orders (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Returns list of all order objects and status counts summary." }
        }
      }
    },
    "/orders/admin/{id}": {
      "put": {
        "summary": "Update Fulfillment Status (Admin/Editor)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["fulfillmentStatus"],
                "properties": {
                  "fulfillmentStatus": { "type": "string", "enum": ["Unfulfilled", "Processing", "Shipped", "Delivered", "Returned"] },
                  "trackingNumber": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Order status updated and customer notified." }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "summary": "Get Order Details",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Order details returned." }
        }
      }
    },
    "/orders/{id}/invoice": {
      "get": {
        "summary": "Download PDF Invoice",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Streams PDF format file." }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    }
  }
}
